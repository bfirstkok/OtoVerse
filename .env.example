# Firebase (Vite)
# 1) Create a Firebase project
# 2) Enable Authentication providers: Email/Password, Google, GitHub
# 3) Create a Web App in Firebase console and copy config here
# 4) For GitHub provider, you'll need to set OAuth client id/secret in Firebase console

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# Tip: if you use a custom domain on Firebase Hosting, add it to
# Firebase Authentication → Settings → Authorized domains.
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
