rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
    }

    function roomDoc(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function roomExists(roomId) {
      return exists(roomDoc(roomId));
    }

    function roomData(roomId) {
      return get(roomDoc(roomId)).data;
    }

    function isRoomHost(roomId) {
      return isSignedIn() && roomExists(roomId) && roomData(roomId).hostUid == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return isSignedIn() && (
        isRoomHost(roomId)
        || exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid))
      );
    }

    // profiles
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // per-user private data (favorites, local stats, etc.)
    match /user_private/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);

      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && (request.auth.uid in request.resource.data.participants)
        && chatId == (request.resource.data.participants[0] + "__" + request.resource.data.participants[1]);

      // allow updating meta/lastMessage/etc but do NOT allow changing participants
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants)
        && request.resource.data.participants == resource.data.participants;

      allow delete: if false;
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read: if isChatParticipant(chatId);

      allow create: if isChatParticipant(chatId)
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000;

      allow update, delete: if false;
    }

    // song requests
    match /song_requests/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.requestText is string
        && request.resource.data.requestText.size() > 0
        && request.resource.data.requestText.size() <= 220;

      allow read, update, delete: if false;
    }

    // reports (bug reports / video issues)
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt is timestamp;

      allow read, update, delete: if false;
    }

    // online rooms
    match /rooms/{roomId} {
      // Public room list shows only listed lobby rooms.
      allow list: if isSignedIn() && resource.data.isListed == true && resource.data.status == "lobby";

      // Allow opening a room doc if it's listed OR you're already a member OR it's a lobby room you know the id for.
      allow get: if isSignedIn() && (
        resource.data.isListed == true
        || isRoomMember(roomId)
        || resource.data.status == "lobby"
      );

      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "lobby"
        && request.resource.data.roomName is string
        && request.resource.data.roomName.size() > 0
        && request.resource.data.roomName.size() <= 40
        && request.resource.data.hostNickname is string
        && request.resource.data.hostNickname.size() > 0
        && request.resource.data.hostNickname.size() <= 14
        && request.resource.data.gameMode is string
        && request.resource.data.gameMode in ["standard", "battle_royale"]
        && request.resource.data.answerMode is string
        && request.resource.data.questionCount is int
        && request.resource.data.perQuestionMs is int;

      // Host can update anything; non-host can only touch updatedAt (used as a heartbeat).
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.hostUid
        || request.resource.data.diff(resource.data).changedKeys().hasOnly(["updatedAt"])
      );

      allow delete: if false;

      match /players/{uid} {
        allow read: if isSignedIn() && (roomData(roomId).isListed == true || isRoomMember(roomId));

        allow create: if isSignedIn()
          && request.auth.uid == uid
          && roomExists(roomId)
          && roomData(roomId).status in ["lobby", "playing"]
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 14;

        // Player can update own fields; host can reset scores/ready without changing identity fields.
        allow update: if isSignedIn() && (
          (
            request.auth.uid == uid
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.joinedAt == resource.data.joinedAt
            && request.resource.data.nickname is string
            && request.resource.data.nickname.size() > 0
            && request.resource.data.nickname.size() <= 14
          )
          || (
            isRoomHost(roomId)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.nickname == resource.data.nickname
            && request.resource.data.joinedAt == resource.data.joinedAt
          )
        );

        // Player can leave; host can kick.
        allow delete: if isSignedIn() && (request.auth.uid == uid || isRoomHost(roomId));
      }

      // lobby chat
      match /messages/{messageId} {
        allow read: if isSignedIn() && (roomData(roomId).isListed == true || isRoomMember(roomId));

        allow create: if isSignedIn()
          && isRoomMember(roomId)
          && roomExists(roomId)
          && roomData(roomId).status in ["lobby", "playing"]
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 14
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300
          && request.resource.data.createdAt is timestamp;

        allow update, delete: if false;
      }
    }

    // posts + comments (community)
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 2000
        && request.resource.data.imageUrl is string
        && request.resource.data.authorNickname is string
        && request.resource.data.authorPhotoURL is string
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0;

      // author can edit; everyone else can only toggle likedBy (no changing content/author)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid
        || (
          request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.authorNickname == resource.data.authorNickname
          && request.resource.data.authorPhotoURL == resource.data.authorPhotoURL
          && request.resource.data.title == resource.data.title
          && request.resource.data.body == resource.data.body
          && request.resource.data.imageUrl == resource.data.imageUrl
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.likedBy is list
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.authorUid;

      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 1000
          && request.resource.data.authorNickname is string
          && request.resource.data.authorPhotoURL is string;

        allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorUid;
      }
    }
  }
}
